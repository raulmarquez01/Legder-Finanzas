        "id": "c890cb65",
        "outputId": "a7578efb-3900-435b-a2a3-b9004f52f42c"
      },
      "source": [
        "# 3. Descarga de datos desde Yahoo Finance\n",
        "FECHA_FIN    = datetime.today().strftime('%Y-%m-%d')\n",
        "FECHA_INICIO = (datetime.today() - timedelta(days=365 * 15)).strftime('%Y-%m-%d')\n",
        "\n",
        "# Descargamos los datos\n",
        "raw = yf.download(tickers=TICKERS, start=FECHA_INICIO, end=FECHA_FIN, threads=True, group_by='ticker')\n",
        "\n",
        "frames = []\n",
        "for tk in TICKERS:\n",
        "    # Verificamos si el ticker está presente en las columnas para evitar el KeyError\n",
        "    if tk in raw.columns.levels[0]:\n",
        "        df_tk = raw[tk].copy().reset_index()\n",
        "        df_tk['ticker'] = tk\n",
        "        # Renombramos columnas estándar\n",
        "        df_tk = df_tk.rename(columns={'Date': 'date', 'Open': 'open', 'High': 'high', 'Low': 'low', 'Close': 'close', 'Volume': 'volume'})\n",
        "        # Seleccionamos solo las columnas necesarias\n",
        "        df_tk = df_tk[['date', 'ticker', 'open', 'high', 'low', 'close', 'volume']]\n",
        "        frames.append(df_tk)\n",
        "    else:\n",
        "        print(f'⚠️ No se encontraron datos para: {tk}')\n",
        "\n",
        "# Unificamos todo en un solo DataFrame\n",
        "if frames:\n",
        "    df_prices = pd.concat(frames, ignore_index=True).dropna(subset=['close'])\n",
        "    df_prices['date'] = pd.to_datetime(df_prices['date']).dt.strftime('%Y-%m-%d')\n",
        "    print(f'✅ Descargadas {len(df_prices):,} filas.')\n",
        "else:\n",
        "    print('❌ No se descargó ningún dato.')"
      ],
