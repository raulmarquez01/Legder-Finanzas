      "source": [
        "# 6. Query 3: Creación de Tabla Derivada (Retornos Diarios)\n",
        "# Calculamos el cambio porcentual diario usando la función de ventana LAG()\n",
        "cur.execute('DROP TABLE IF EXISTS retornos_diarios')\n",
        "cur.execute('''\n",
        "    CREATE TABLE retornos_diarios AS\n",
        "    SELECT\n",
        "        date,\n",
        "        ticker,\n",
        "        close,\n",
        "        ROUND(\n",
        "            (close - LAG(close) OVER (PARTITION BY ticker ORDER BY date))\n",
        "            / LAG(close) OVER (PARTITION BY ticker ORDER BY date) * 100,\n",
        "        4) AS retorno_pct\n",
        "    FROM prices\n",
        "''')\n",
        "conn.commit()\n",
        "\n",
        "print(\"✅ Tabla 'retornos_diarios' creada.\")\n",
        "# Mostrar un pequeño ejemplo de los resultados\n",
        "display(pd.read_sql('SELECT * FROM retornos_diarios WHERE retorno_pct IS NOT NULL LIMIT 5', conn))"
      ],
