      "source": [
        "# 4. Creación de Base de Datos SQLite\n",
        "conn = sqlite3.connect('mercado.db')\n",
        "cur = conn.cursor()\n",
        "\n",
        "cur.execute('DROP TABLE IF EXISTS prices')\n",
        "cur.execute('DROP TABLE IF EXISTS tickers')\n",
        "\n",
        "cur.execute('CREATE TABLE tickers (symbol TEXT PRIMARY KEY, sector TEXT, exchange TEXT)')\n",
        "cur.execute('CREATE TABLE prices (date TEXT, ticker TEXT, open REAL, high REAL, low REAL, close REAL, volume INTEGER, FOREIGN KEY(ticker) REFERENCES tickers(symbol))')\n",
        "\n",
        "cur.executemany('INSERT INTO tickers VALUES (?, ?, ?)', TICKERS_META)\n",
        "df_prices.to_sql('prices', conn, if_exists='append', index=False)\n",
        "conn.commit()\n",
        "print('✅ Base de datos mercado.db creada y poblada.')"
      ],
